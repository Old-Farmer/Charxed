{
  "auto_indent": true,
  "auto_pair": true,
  "max_edit_history": 100,
  "tab_space": true,
  "tab_stop": 4,
  "wrap": false,

  "end_of_buffer_mark": false,
  "highlight_cursor_line": true,
  "line_number": 2,
  "scroll_off": 8,
  "trailing_white": true,

  "basic_word_completion": true,
  "cmp_menu_max_height": 15,
  "cmp_menu_max_width": 100,
  "colorscheme": "default",
  "explorer_indent": 2,
  "highlight_on_search": true,
  "input_idle_timeout": 50,
  "logverbose": false,
  "max_peel_history": 100,
  "max_jump_history": 100,
  "search_ignore_case": true,
  "scroll_rows": 3,
  "truecolor": true,

  "cursor_start_holding_interval": 500,

  "makefile": {
    "tab_space": false
  },
  "markdown": {
    "wrap": true
  },
  "text": {
    "wrap": true
  }
}
